# =============================================================================
# AI Video Production Factory - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- Database -----
POSTGRES_USER=aivideo
POSTGRES_PASSWORD=aivideo_secret
POSTGRES_DB=aivideo

# ----- Redis -----
# Redis is configured automatically via docker-compose

# ----- Security -----
# IMPORTANT: Change this in production! Use: openssl rand -hex 32
SECRET_KEY=change_me_in_production_min_32_chars_!!

# ----- Admin User (seeded on first start) -----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Adm1n$ecure42!

# ----- Service Ports -----
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ----- Frontend API URL -----
# URL used by the browser to reach the backend API.
# Development: http://localhost:8000/api/v1
# Production:  https://your-domain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ----- Storage -----
# LOCAL (default): Files stored in Docker volume
STORAGE_PATH=/storage

# OPTIONAL: S3-compatible storage (leave empty to use local)
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1

# ----- AI Script Generation -----
# Leave empty to use placeholder provider (no AI scripts)
OPENAI_API_KEY=
# Override base URL for compatible providers (LM Studio, Together AI, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Claude/Anthropic (optional)
ANTHROPIC_API_KEY=

# ----- Text-to-Speech -----
# Edge-TTS: Free, no API key needed
EDGE_TTS_ENABLED=true
EDGE_TTS_DEFAULT_VOICE=en-US-JennyNeural

# Coqui TTS: Optional local TTS server
COQUI_TTS_ENABLED=false
COQUI_TTS_URL=http://coqui-tts:5002

# ----- Caption / Transcription -----
# faster-whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
# Set to cuda if you have GPU
# WHISPER_DEVICE=cuda

# ----- Stock Media -----
# Pexels API (free tier available): https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay API (free tier available): https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ----- YouTube Upload (Optional) -----
YOUTUBE_UPLOAD_ENABLED=false
# Path to OAuth2 client secrets JSON file
YOUTUBE_CLIENT_SECRETS_FILE=

# ----- Job Settings -----
MAX_JOB_RETRIES=3
DRY_RUN=false

# ----- GPU Rendering (Optional) -----
# Set to 'all' to enable NVIDIA NVENC
NVIDIA_VISIBLE_DEVICES=void
NVIDIA_NVENC_ENABLED=false

# ----- Feature Flags -----
# Enable/disable modules (true/false)
FEATURE_CORE_VIDEO=true
FEATURE_AI_SCRIPTS=true
FEATURE_TRENDS=true
FEATURE_TTS=true
FEATURE_CAPTIONS=true
FEATURE_STOCK_MEDIA=true
FEATURE_N8N=true
FEATURE_YOUTUBE_UPLOAD=false
FEATURE_SOCIAL_UPLOADERS=false
FEATURE_GPU_RENDERING=false
FEATURE_CLOUD_STORAGE=false
